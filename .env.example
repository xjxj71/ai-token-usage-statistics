# AI Token Usage Statistics - Environment Configuration
# Copy this file to .env and modify as needed

# WSL distribution name (for UNC path access)
# TOKEN_STAT_WSL_DISTRO=project-claude

# Server bind address and port
# TOKEN_STAT_HOST=127.0.0.1
# TOKEN_STAT_PORT=8001

# Collector polling interval (seconds)
# TOKEN_STAT_POLL_INTERVAL_SECONDS=5

# Database path
# TOKEN_STAT_DB_PATH=data/token_statistic.db

# API Key (optional, leave empty to disable auth)
# TOKEN_STAT_API_KEY=
